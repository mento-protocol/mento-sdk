{
  "name": "@mento-protocol/mento-sdk",
  "description": "Official SDK for interacting with the Mento Protocol",
  "version": "3.1.0",
  "license": "MIT",
  "author": "Mento Labs",
  "keywords": [
    "mento",
    "defi",
    "swap",
    "stablecoin",
    "sdk",
    "blockchain",
    "web3",
    "viem"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mento-protocol/mento-sdk.git"
  },
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.map"
  ],
  "type": "commonjs",
  "scripts": {
    "build": "pnpm clean && tsc --project ./tsconfig.json && tsc --project ./tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "clean": "rm -rf ./dist",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "prettier": "prettier --config ./.prettierrc.json --write **/*.{json,md,js,ts,yml}",
    "test": "jest --verbose",
    "test:unit": "jest --verbose --testPathPatterns='tests/unit'",
    "test:integration": "jest --verbose --testPathPatterns='tests/integration'",
    "coverage": "jest --coverage",
    "size": "size-limit",
    "cacheRoutes": "ts-node scripts/cacheRoutes/index.ts",
    "cacheTokens": "ts-node scripts/cacheTokens/index.ts"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@jest/types": "^30.2.0",
    "size-limit": "^12.0.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@tsconfig/recommended": "^1.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/yargs-parser": "^21.0.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.0.0",
    "typescript-eslint": "^8.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "yargs-parser": "^22.0.0",
    "dotenv": "^17.3.1"
  },
  "dependencies": {
    "viem": "^2.21.44"
  }
}
